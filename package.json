{
  "name": "chooks-template",
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "mise build",
    "test": "LOG_LEVEL=error VITE_CJS_TRACE=true vitest",
    "xrpld:start": "xrpld-netgen up:standalone --protocol xahau --version $XAHAU_VERSION",
    "xrpld:stop": "xrpld-netgen down:standalone --protocol xahau --version $XAHAU_VERSION",
    "trace": "docker logs --tail 100 -f xahau 2>&1 | cut -d ' ' -f 5- | grep -a -E 'Publishing ledger|HookInfo|HookTrace|HookError|HookEmit|preclaim result'",
    "trace:raw": "docker logs --tail 100 -f xahau"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@transia/hooks-toolkit": "npm:@tequ/hooks-toolkit@2.0.0-peer-dep",
    "dotenv": "^16.4.1",
    "xahau": "^4.0.3",
    "xahau-binary-codec": "^2.1.3",
    "xahau-keypairs": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.5.3",
    "@tsconfig/node18": "^18.2.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
